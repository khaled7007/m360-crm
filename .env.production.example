# SCCC ACR (Alibaba Cloud Saudi Container Registry)
# Find this in SCCC Console → Container Registry → Instance → Access Credential
ACR_REGISTRY=registry.me-central-1.cr.aliyuncs.com

# Database
DB_USER=m360
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=m360

# Redis
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# JWT
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# App
API_URL=http://YOUR_SERVER_IP
IMAGE_TAG=latest
